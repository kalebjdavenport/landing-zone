# Supabase (required for persistence + realtime)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# NWS API identifies callers by User-Agent
NWS_USER_AGENT=LandingZone/1.0 (dispatch@example.com)

# Optional: internal token for scheduled ingest endpoints
INGEST_INTERNAL_TOKEN=

# Optional: HMAC secret for webhook verification (x-signature: sha256=<hex>)
WEBHOOK_SIGNING_SECRET=
