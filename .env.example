# Supabase (required for persistence + realtime)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# NWS API identifies callers by User-Agent
NWS_USER_AGENT=LandingZone/1.0 (dispatch@example.com)

# OpenWeatherMap — free tier key for cloud/temperature map tiles (optional)
# Sign up at https://openweathermap.org/api — the key enables Clouds and Temp layers.
# Radar (NEXRAD via Iowa State Mesonet) works without any key.
NEXT_PUBLIC_OWM_KEY=

# Optional: internal token for scheduled ingest endpoints
INGEST_INTERNAL_TOKEN=

# Optional: HMAC secret for webhook verification (x-signature: sha256=<hex>)
WEBHOOK_SIGNING_SECRET=
